// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  CONVERT
  SALE
  INTEREST
  BUSINESS
  PERSONAL
}

enum ClientSyncTrigger {
  AUTOMATIC
  MANUAL
}

enum ClientSyncOutcome {
  SUCCEEDED
  FAILED
}

// Models
model User {
  id            Int       @id @default(autoincrement())
  firstName     String    @default("")
  lastName      String    @default("")
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  businesses Business[]
  accounts   Account[]

  @@map("user")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Business {
  id     Int    @id @default(autoincrement())
  userId Int
  name   String

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  clients              Client[]
  transactions         Transaction[]
  reconciliations      Reconciliation[]
  cardBalanceSnapshots CardBalanceSnapshot[]
  cashBalanceSnapshots CashBalanceSnapshot[]
  clientSyncAttempts   ClientSyncAttempt[]

  @@index([userId])
  @@map("business")
}

model Client {
  id          Int     @id @default(autoincrement())
  businessId  Int
  firstName   String
  lastName    String
  phoneNumber String?
  email       String?

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
  @@map("client")
}

model ClientSyncAttempt {
  id          Int                 @id @default(autoincrement())
  businessId  Int
  attemptedAt DateTime            @default(now())
  trigger     ClientSyncTrigger
  outcome     ClientSyncOutcome
  errors      Json?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([attemptedAt])
  @@map("client_sync_attempt")
}

model Transaction {
  id         Int                 @id @default(autoincrement())
  businessId Int
  type       TransactionType
  category   TransactionCategory
  clientId   Int?

  cardAmount Decimal             @default(0) @db.Decimal(12, 2)
  cashAmount Decimal             @default(0) @db.Decimal(12, 2)
  notes      String?

  occurredAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client     Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([clientId])
  @@index([occurredAt])
  @@map("transaction")
}

model CardBalanceSnapshot {
  id         Int      @id @default(autoincrement())
  businessId Int
  total      Decimal  @db.Decimal(12, 2)
  recordedAt DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([recordedAt])
  @@map("card_balance_snapshot")
}

model CashBalanceSnapshot {
  id         Int      @id @default(autoincrement())
  businessId Int
  fives      Int      @default(0)
  tens       Int      @default(0)
  twenties   Int      @default(0)
  fifties    Int      @default(0)
  hundreds   Int      @default(0)
  recordedAt DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([recordedAt])
  @@map("cash_balance_snapshot")
}

model Reconciliation {
  id               Int      @id @default(autoincrement())
  businessId       Int
  startPeriod      DateTime
  endPeriod        DateTime
  expectedCash     Decimal             @default(0) @db.Decimal(12, 2)
  expectedCard     Decimal             @default(0) @db.Decimal(12, 2)
  actualCash       Decimal             @default(0) @db.Decimal(12, 2)
  actualCard       Decimal             @default(0) @db.Decimal(12, 2)
  updatedAt        DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([updatedAt])
  @@map("reconciliation")
}
